{
  "name": "student-reality-lab-vazquez",
  "version": "1.0.0",
  "private": true,
  "description": "Phase 2: Data pipeline + web app with integrated AI CLI toolset",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "dev:api": "npm --prefix ai-orchestration-nextjs run dev -- --port 3000",
    "dev:all": "concurrently \"npm:dev\" \"npm:dev:api\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "process-data": "tsx src/lib/processData.ts",
    "cli": "node cli/index.js",
    "cli:help": "node cli/index.js help",
    "cli:status": "node cli/index.js status"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.2",
    "dotenv": "^16.6.1",
    "marked": "^18.0.3",
    "openai": "^4.104.0",
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
