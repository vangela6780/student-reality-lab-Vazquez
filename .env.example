# ⚠️ SECURITY: Store your real OPENAI_API_KEY in .env (not in git!)
# Never commit the real API key to version control
OPENAI_API_KEY=your-openai-api-key-here

# Backend API prefix configuration
# Local dev: /api (Vite dev proxy routes /api/* to localhost:3000)
# Production: https://your-vercel-backend.vercel.app/api (full URL to backend /api/* endpoints)
VITE_BACKEND_URL=/api

